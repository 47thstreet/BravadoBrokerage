{
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/((?!assets|attached_assets|favicon).*)", "destination": "/index.html" }
  ]
}
